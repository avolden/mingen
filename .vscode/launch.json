	"version": "0.2.0",
	"configurations": [
		{
			"name": "(Windows) Launch debug",
			"type": "cppvsdbg",
			"request": "launch",
			"program": "${workspaceFolder}/bin/mingen.exe",
			"args": [
				"-d",
				"C:/Dev/Sources/space-boxes",
				"--compile-db"
			],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"console": "integratedTerminal",
			"preLaunchTask": "build windows"
		},
		{
			"name": "(Windows) Launch release",
			"type": "cppvsdbg",
			"request": "launch",
			"program": "${workspaceFolder}/bin/mingen.exe",
			"args": [
				"-d",
				"tests",
				"-c",
				"release",
				"--compile-db"
			],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			"console": "integratedTerminal",
			"preLaunchTask": "build windows"
		},
		{
			"name": "(Linux) Launch debug",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/bin/mingen",
			"args": [
				"-d",
				"/Users/aubin/Dev/Sources/vulkanbox/"
			],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			// "console": "integratedTerminal",
			"preLaunchTask": "build linux"
		},
		{
			"name": "(Linux) Launch release",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/bin/mingen",
			"args": [
				"-d",
				"tests",
				"-c",
				"release",
				"--compile-db"
			],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [],
			// "console": "integratedTerminal",
			"preLaunchTask": "build linux"
		},
		{
			"name": "(Mac) Launch debug",
			"type": "lldb-dap",
			"request": "launch",
			"program": "${workspaceFolder}/bin/mingen",
			"args": [
				"-d",
				"/Users/aubin/Dev/Sources/vulkanbox/"
			],
			"cwd": "${workspaceFolder}",
			// "console": "integratedTerminal",
			"preLaunchTask": "build mac"
		},
	]
}